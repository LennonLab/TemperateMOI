theme_set(theme_minimal() + theme_all_12)


MOI <- read.csv("data/20251113_CombinedMOI.csv")
MOI$virus <- ifelse(MOI$virus=="WT", "Temperate", "Lytic")

data.group <- MOI %>% group_by(virus, moi.log) %>%
  summarise(norm.avg = mean(norm), pfu.avg = mean(pfus))



