```{r}
library(tidyverse)
library(PNWColors)
library(ggpubr)
library(here)
```


##Cleaning MOI from 9/10-9/13, which were various MOIS for temp (-4 to -6) and lytic (-4 to -2)

```{r}
MOI46 <- read.csv(here("MOI/data/20251113_1204_MOI6_4_EB.csv"))


MOI46$plaque.count <- ifelse(MOI46$plaque.count=="TNTC" | MOI46$plaque.count=="0", NA, MOI46$plaque.count) 

## turn Count column into "numeric" category of MOI46 so that R recognizes it is numbers, not words.
MOI46$plaque.count <- as.numeric(MOI46$plaque.count)

##plated 100ul

MOI46$pfus <- (MOI46$plaque.count / 100) * 1000 / MOI46$dilution

MOI46$norm <- log10(MOI46$pfus)
```
